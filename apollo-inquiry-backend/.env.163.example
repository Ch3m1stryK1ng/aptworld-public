# .env.163.example  —— 适配【网易企业邮箱】的默认配置
PORT=3000

# 网易企业邮箱 SMTP (常用：SSL 465；或 STARTTLS 587)
SMTP_HOST=smtp.qiye.163.com
SMTP_PORT=465
SMTP_SECURE=true

# 账号与授权码（不是登录密码！是在邮箱安全设置里为客户端/SMTP生成的授权码）
SMTP_USER=your_account@yourdomain.com
SMTP_PASS=your_client_auth_code

# 发信人（可与 SMTP_USER 相同，或使用“名称 <邮箱>”形式）
SMTP_FROM=Website <your_account@yourdomain.com>

# 收件人（可多个人，逗号分隔）
TO_EMAILS=xjyang@apollopt.com.cn
