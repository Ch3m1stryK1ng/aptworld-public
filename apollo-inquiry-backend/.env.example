# .env.example
# Server
PORT=3000

# Mail (fill with your SMTP)
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_username@example.com
SMTP_PASS=your_smtp_password_or_app_code
SMTP_FROM=Website <your_smtp_username@example.com>

# Recipient(s) - comma separated allowed
TO_EMAILS=xjyang@apollopt.com.cn
